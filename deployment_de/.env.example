# MGRSoftware + AgroBetrieb NAS Multi-Instanz Deployment
# Diese Datei als .env im gleichen Verzeichnis wie docker-compose-nas.yml ablegen

# Domain für Caddy (z.B. nas.example.com oder localhost)
DOMAIN=meinedomain.myfritz.net

# Optional: Pfad zum Pro-Paket
PRO_PACKAGE_PATH=/volume1/docker/mgrsoftware-pro

# ── MGRSoftware: mg (Hauptinstanz) ────────────────────────
